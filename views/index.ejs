<%- include('partials/header', { title }) %>

<div class="main-container">
  <header class="app-header">
    <div class="title-container">
      <h1 class="cyber-title"><span>L</span><span>i</span><span>n</span><span>k</span><span>P</span><span>a</span><span>s</span><span>t</span><span>e</span><span class="title-sep">&nbsp;-&nbsp;</span><span>A</span><span>I</span></h1>
    </div>
    <p class="app-description">粘贴 AI 灵感，分享无限可能</p>
  </header>

  <div class="content-area">
    <!-- 代码输入卡片 -->
    <div class="card input-card">
      <!-- HTML 输入区域 -->
      <div class="input-section">
        <!-- 移除了标签切换，默认只显示粘贴框 -->
        
        <!-- 加载指示器 -->
        <div id="loading-indicator" class="loading-indicator">
          <div class="spinner"></div>
          <span>处理中...</span>
        </div>
        
        <!-- 代码输入 -->
        <div id="code-input-container" role="tabpanel">
          <!-- 代码类型指示器 + 退出按钮同行 -->
          <div class="indicator-row">
            <div id="code-type-indicator" class="code-type-indicator html-type">
              <i class="fas fa-code"></i>
              <span id="code-type-text">HTML</span>
            </div>
            <a href="/logout" class="logout-btn" title="退出登录">
              <i class="fas fa-sign-out-alt"></i> 退出
            </a>
          </div>
          <textarea id="html-input" class="cyber-input" placeholder="在这里粘贴你的 HTML/Markdown/SVG/Mermaid 代码..." aria-label="HTML 代码输入区域"></textarea>
        </div>
        
        <!-- 隐藏文件上传区域，但保留文件上传功能 -->
        <div style="display: none;">
          <input id="html-file" type="file" class="hidden" accept=".html,.htm" aria-label="上传 HTML 文件" />
          <p id="file-name" class="mt-3" style="color: var(--primary);"></p>
        </div>
        
        <!-- Markdown 风格选择器（仅当检测到 Markdown 内容时显示） -->
        <div id="md-theme-selector" style="display: none; margin-top: 12px;">
          <div class="md-theme-selector-bar">
            <span class="md-theme-selector-label">
              <i class="fab fa-markdown" style="margin-right:5px; opacity:0.7;"></i>Markdown 风格
            </span>
            <div class="md-theme-selector-swatches" id="md-theme-swatches">
              <!-- 由 JS 动态生成 -->
            </div>
          </div>
        </div>

        <!-- 按钮 -->
        <div class="mt-4 flex justify-between" style="display: flex; justify-content: space-between; margin-top: 1rem;">
          <div>
            <label for="html-file" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="上传HTML文件" aria-label="上传HTML文件">
              <i class="fas fa-file-upload mr-1" aria-hidden="true"></i>上传文件
            </label>
          </div>
          <div style="display: flex; gap: 12px;">
            <button id="clear-button" class="cyber-btn cyber-btn-secondary tooltip micro-interaction" data-tooltip="清空内容" aria-label="清空内容">
              <i class="fas fa-eraser mr-1" aria-hidden="true"></i>清除
            </button>
            <button id="generate-button" class="cyber-btn cyber-btn-primary tooltip micro-interaction" data-tooltip="生成分享链接" aria-label="生成分享链接">
              <i class="fas fa-link mr-1" aria-hidden="true"></i>生成链接
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 用户项目（每个项目独立分享链接）与版本历史 -->
    <div id="asset-panel" class="card input-card" style="margin-top: 1.25rem;">
      <h3 class="section-title" style="color: var(--primary); font-family: 'Orbitron', sans-serif; margin-bottom: 0.75rem;">
        <i class="fas fa-gem" style="margin-right: 8px; opacity: 0.85;"></i>我的项目
      </h3>
      <p class="asset-hint" style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.75rem;">
        每个项目有独立分享链接。选中项目后可编辑原文并保存（链接不变）；也可从历史版本载入或恢复。
      </p>
      <div id="asset-meta" style="margin-bottom: 0.75rem; color: var(--text-secondary); font-size: 0.9rem;"></div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px;">
        <button type="button" id="new-project-btn" class="cyber-btn cyber-btn-secondary" style="padding: 6px 12px; font-size: 0.85rem;">
          <i class="fas fa-plus"></i> 新建项目
        </button>
        <button type="button" id="refresh-projects-btn" class="cyber-btn cyber-btn-secondary" style="padding: 6px 12px; font-size: 0.85rem;">
          <i class="fas fa-sync-alt"></i> 刷新项目
        </button>
      </div>
      <div id="projects-list" class="projects-list" aria-live="polite" style="margin-bottom: 1.25rem;"></div>
      <p id="projects-empty" style="color: var(--text-secondary); font-size: 0.9rem; display: none;">暂无项目，在上方编辑内容后点击「生成链接」将创建第一个项目。</p>

      <h4 style="color: var(--primary); font-size: 1rem; margin-bottom: 0.5rem;">当前项目的版本历史</h4>
      <div id="versions-toolbar" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px;">
        <button type="button" id="refresh-versions-btn" class="cyber-btn cyber-btn-secondary" style="padding: 6px 12px; font-size: 0.85rem;">
          <i class="fas fa-sync-alt"></i> 刷新版本
        </button>
      </div>
      <div id="versions-list" class="versions-list" aria-live="polite"></div>
      <p id="versions-empty" style="color: var(--text-secondary); font-size: 0.9rem; display: none;">请先在上方「我的项目」中选择一个项目，或保存生成链接后再查看版本。</p>
    </div>
    
    <!-- 结果区域卡片 -->
    <div id="result-section" class="card result-card" style="display: none;" aria-live="polite">
      <h3 class="section-title" style="color: var(--primary); font-family: 'Orbitron', sans-serif; margin-bottom: 1rem;">链接已生成</h3>
      <div class="result-container">
        <div id="result-url" class="result-url" tabindex="0"></div>
        <div class="action-buttons">
          <button id="preview-button" class="action-btn preview-btn tooltip micro-interaction" data-tooltip="在新窗口预览" aria-label="在新窗口预览">
            <i class="fas fa-external-link-alt" aria-hidden="true"></i>
          </button>
          <button id="copy-button" class="action-btn tooltip micro-interaction" data-tooltip="复制链接" aria-label="复制链接">
            <i class="fas fa-copy" aria-hidden="true"></i>
          </button>
        </div>
      </div>
      
      <!-- 密码保护开关 -->
      <div class="password-protection-toggle">
        <div class="protection-controls">
          <div class="switch-container">
            <input type="checkbox" id="password-toggle" class="switch-checkbox">
            <label for="password-toggle" class="switch-label"></label>
          </div>
          <div id="password-info" class="password-info" style="display: none; margin-left: 15px;">
            <span id="generated-password" class="generated-password" style="display: inline-block; cursor: pointer;" title="点击复制密码"></span>
            <a href="#" id="copy-password-link" class="copy-password-link" style="display: inline-block; margin-left: 10px;">复制密码和网址</a>
          </div>
        </div>
      </div>
      

    </div>
  </div>
  
  <footer class="app-footer">
    <p class="footer-text">@2026 LinkPaste AI | 粘贴 AI 灵感，分享无限可能</p>
  </footer>
</div>

<%- include('partials/footer') %>
